# --- Database (PostgreSQL + PostGIS) ---
DB_NAME=scalaris_db
DB_USER=scalaris_user
DB_PASSWORD=scalaris_pass
DB_HOST=localhost
DB_PORT=5432

# --- Django ---
SECRET_KEY=change-me-to-a-random-secret-key

# --- Redis (channels layer) ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# --- Email (SMTP, used for password reset) ---
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# --- Frontend URL (used in reset-link emails + Discord redirect allow-list) ---
FRONTEND_URL=https://localhost:5174

# --- Geo libraries (system paths; adjust to your install) ---
# Windows (OSGeo4W):
GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal313.dll
GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll
# macOS (Homebrew):
# GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# --- Discord OAuth2 (https://discord.com/developers/applications) ---
# Add redirect URI: https://localhost:5174/oauth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://localhost:5174/oauth/discord/callback

# --- Cookie security (set true in production over HTTPS) ---
AUTH_COOKIE_SECURE=False

DB_NAME=scalaris_db
DB_USER=scalaris_user
DB_PASSWORD=scalaris_pass
DB_HOST=localhost
DB_PORT=5432
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Windows only — path to OSGeo4W GDAL/GEOS libraries
# GDAL_LIBRARY_PATH=C:\OSGeo4W\bin\gdal313.dll
# GEOS_LIBRARY_PATH=C:\OSGeo4W\bin\geos_c.dll

# macOS only
# GDAL_LIBRARY_PATH=/opt/homebrew/opt/gdal/lib/libgdal.dylib
# GEOS_LIBRARY_PATH=/opt/homebrew/opt/geos/lib/libgeos_c.dylib

# Discord OAuth (backend) — client_secret лишається тільки тут
# redirect_uri має збігатися з тим, що зареєстровано в Discord Developer Portal
# і з фронтенд-колбеком: https://localhost:5174/oauth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://localhost:5174/oauth/discord/callback

FRONTEND_URL=https://localhost:5174

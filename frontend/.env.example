# Куди Vite проксує /api та /media під час dev (локальний Django за замовчуванням)
# VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Discord Application client_id (Application ID) з https://discord.com/developers/applications
# Це публічний ідентифікатор, безпечно тримати на фронтенді — client_secret лишається лише на бекенді.
# У Discord Developer Portal додай redirect: https://localhost:5174/oauth/discord/callback
VITE_DISCORD_CLIENT_ID=
